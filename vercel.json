{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "generate_seo.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/evaluate",
      "dest": "server.js"
    },
    {
      "src": "/stats",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
